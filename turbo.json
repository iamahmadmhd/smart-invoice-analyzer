{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "outputs": ["dist/**", "cdk.out/**"]
        },
        "lint": {},
        "check-types": {
            "dependsOn": ["^build"]
        },
        "synth": {
            "dependsOn": ["build"],
            "outputs": ["cdk.out/**"]
        },
        "start": {
            "cache": false,
            "persistent": true
        },
        "android": {
            "cache": false,
            "persistent": true
        },
        "ios": {
            "cache": false,
            "persistent": true
        }
    }
}
