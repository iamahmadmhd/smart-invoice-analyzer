{
    "expo": {
        "name": "Smart Invoice Analyzer",
        "slug": "smart-invoice-analyzer",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "scheme": "smart-invoice-analyzer",
        "userInterfaceStyle": "automatic",
        "ios": {
            "icon": "./assets/expo.icon",
            "bundleIdentifier": "com.anonymous.smartinvoiceanalyzer"
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#E6F4FE",
                "foregroundImage": "./assets/images/android-icon-foreground.png",
                "backgroundImage": "./assets/images/android-icon-background.png",
                "monochromeImage": "./assets/images/android-icon-monochrome.png"
            },
            "predictiveBackGestureEnabled": false,
            "package": "com.anonymous.smartinvoiceanalyzer"
        },
        "web": {
            "output": "server",
            "favicon": "./assets/images/favicon.png"
        },
        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "backgroundColor": "#208AEF",
                    "android": {
                        "image": "./assets/images/splash-icon.png",
                        "imageWidth": 76
                    }
                }
            ],
            "expo-image",
            [
                "expo-image-picker",
                {
                    "cameraPermission": "This app uses the camera to scan and upload invoices and receipts.",
                    "microphonePermission": false,
                    "photosPermission": "This app accesses your photos to let you upload invoices and receipts."
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "ddd559a3-2259-4aa3-945f-d2ffabc4223a"
            }
        },
        "owner": "iamahmadmhd"
    }
}
