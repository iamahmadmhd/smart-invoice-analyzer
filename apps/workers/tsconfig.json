{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["es2022"],
        "strict": true,
        "skipLibCheck": true,
        "types": ["node"],
        "noEmit": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
