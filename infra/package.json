{
    "name": "@smart-invoice-analyzer/infra",
    "version": "0.1.0",
    "private": true,
    "main": "bin/app.js",
    "scripts": {
        "build": "echo 'No build for infra'",
        "watch": "tsc -w",
        "cdk": "cdk",
        "deploy:dev": "cdk deploy SmartInvoiceAnalyzer-Dev --require-approval never",
        "deploy:pipeline": "cdk deploy SmartInvoiceAnalyzer-Pipeline --require-approval never",
        "synth": "cdk synth",
        "synth:dev": "cdk synth SmartInvoiceAnalyzer-Dev",
        "synth:pipeline": "cdk synth SmartInvoiceAnalyzer-Pipeline",
        "diff:dev": "cdk diff SmartInvoiceAnalyzer-Dev",
        "diff:pipeline": "cdk diff SmartInvoiceAnalyzer-Pipeline",
        "lint": "echo 'No lint for infra'",
        "check-types": "tsc --noEmit"
    },
    "devDependencies": {
        "@types/jest": "^30",
        "@types/node": "^24.10.1",
        "aws-cdk": "2.1108.0",
        "jest": "^30",
        "ts-jest": "^29",
        "ts-node": "^10.9.2",
        "typescript": "~5.9.3"
    },
    "dependencies": {
        "aws-cdk-lib": "^2.240.0",
        "constructs": "^10.5.0"
    }
}
